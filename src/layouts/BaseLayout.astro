---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import PagefindConfig from "astro-pagefind/components/PagefindConfig.astro";

type Props = {
  title: string;
  description?: string;
  wide?: boolean;
  current?: "home" | "catalog" | "about" | "glossary" | "decisions" | "trails" | "changelog" | "resources" | "chapter";
  footerCurrent?: "about" | "glossary" | "changelog";
};

const { title, description, wide = false, current, footerCurrent } = Astro.props;
const fullTitle = title === "Home" ? "AI-Native Product Building" : `${title} · AI-Native Product Building`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? "A living handbook for building products when AI changes every step."} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
    <PagefindConfig instance="handbook" lang="en" />
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <div class="grain" aria-hidden="true"></div>
    <SiteHeader current={current === "chapter" ? "catalog" : current} />
    <main id="main-content" class:list={["site-main", wide && "site-main--wide"]}>
      <slot />
    </main>
    <SiteFooter current={footerCurrent} />
    <pagefind-modal instance="handbook" reset-on-close="true"></pagefind-modal>
  </body>
</html>
