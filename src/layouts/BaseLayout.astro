---
import "../styles/global.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";

type Props = {
  title: string;
  description?: string;
  wide?: boolean;
  current?: "home" | "catalog" | "about" | "glossary" | "decisions" | "trails" | "changelog" | "resources";
};

const { title, description, wide = false, current } = Astro.props;
const fullTitle = title === "Home" ? "AI-Native Product Building" : `${title} · AI-Native Product Building`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? "A living handbook for building products when AI changes every step."} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="grain" aria-hidden="true"></div>
    <SiteHeader current={current} />
    <main class:list={["site-main", wide && "site-main--wide"]}>
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
