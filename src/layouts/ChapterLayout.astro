---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description: string;
  phase: string;
  phaseTitle: string;
  status: string;
};

const { title, description, phase, phaseTitle, status } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <header class="chapter-head">
    <p class="hero-eyebrow">{phase} · {phaseTitle}</p>
    <h1>{title}</h1>
    <div class="chapter-meta">
      <span class={`status status-${status}`}>{status}</span>
      <span>principle → decision → workflow → artifact</span>
    </div>
  </header>
  <article class="prose">
    <slot />
  </article>
</BaseLayout>
