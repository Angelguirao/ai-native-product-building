---
import BaseLayout from "../layouts/BaseLayout.astro";
import Catalog from "../components/Catalog.astro";
import { buildCatalogPhases, getHandbookStats } from "../lib/catalog";
import { handbookVersion } from "../data/catalog";

const phases = await buildCatalogPhases();
const stats = await getHandbookStats();
---

<BaseLayout
  title="Home"
  description="A living handbook for building products when AI changes every step — principles, decisions, workflows, artifacts."
  wide={true}
  current="home"
>
  <p class="hero-eyebrow">DEC_000 · handbook v{handbookVersion} · open source</p>
  <h1 class="hero-title">AI-Native<br />Product Building</h1>
  <p class="hero-lede">
    Not how to build AI products — how AI changes the process of building <em>any</em> product.
    Decision frameworks that outlive the tools. Versioned in public like software.
  </p>

  <section class="panel">
    <h2>How this works</h2>
    <p>
      Most material teaches tools in scattered pieces. A Lovable post here, a Cursor tip there, an agent demo somewhere else.
      This handbook is the spine — organized by <strong>decisions founders and product engineers actually make</strong>,
      not by vendor changelog.
    </p>
    <p>Each chapter runs the same loop: <strong>principle → decision → workflow → artifact</strong>. Tools go last and are allowed to age.</p>
  </section>

  <section class="progress-block">
    <div class="progress-meta">
      <span>{stats.refined} refined · {stats.shipped} shipped · {stats.total} chapters</span>
      <span>v{handbookVersion}</span>
      <span>updated {new Date().toISOString().slice(0, 10)}</span>
    </div>
    <div class="progress-bar" role="progressbar" aria-valuenow={stats.progress} aria-valuemin="0" aria-valuemax="100" aria-label="Chapters refined or battle-tested">
      <span style={`width: ${stats.progress}%`}></span>
    </div>
    <p class="progress-hint">
      <a href="/trails">Pick a reading trail</a> · <a href="/decisions">Decision registry</a> · <a href="/changelog">Changelog</a>
    </p>
  </section>

  <h2 class="hero-eyebrow" style="margin-top: 2.5rem">Catalog</h2>
  <p style="color: var(--muted); margin-top: -0.5rem">Tap a phase to expand. Maturity badges show depth — not just ship status.</p>
  <Catalog phases={phases} />

  <p style="margin-top: 2rem; font-size: 0.95rem; color: var(--muted)">
    Inspired by the essay rhythm of <a href="https://www.makingsoftware.com/">Making Software</a>
    and the catalog clarity of <a href="https://aiengineeringfromscratch.com/">AI Engineering from Scratch</a> —
    adapted for product builders, in the warm voice of <a href="https://angelguirao.com/wiki">footnotes</a>.
  </p>
</BaseLayout>
