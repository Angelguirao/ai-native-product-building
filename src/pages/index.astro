---
import BaseLayout from "../layouts/BaseLayout.astro";
import EntryCards from "../components/EntryCards.astro";
import { getHandbookStats, getOrderedChapters } from "../lib/catalog";
import { handbookVersion } from "../data/catalog";

const stats = await getHandbookStats();
const chapters = await getOrderedChapters();
const featured = chapters.filter(
  (c) => c.maturity === "refined" || c.maturity === "battle-tested",
);
---

<BaseLayout
  title="Home"
  description="A living handbook for building products when AI changes every step — principles, decisions, workflows, artifacts."
  wide={true}
  current="home"
>
  <p class="hero-eyebrow">DEC_000 · handbook v{handbookVersion} · open source</p>
  <h1 class="hero-title">AI-Native<br />Product Building</h1>
  <p class="hero-lede">
    Not how to build AI products — how AI changes the process of building <em>any</em> product.
    Decision frameworks that outlive the tools. Versioned in public like software.
  </p>

  <EntryCards />

  <section class="panel">
    <h2>How this works</h2>
    <p>
      Most material teaches tools in scattered pieces. This handbook is the spine — organized by
      <strong>decisions founders and product engineers actually make</strong>, not by vendor changelog.
    </p>
    <p>Each chapter runs the same loop: <strong>principle → decision → workflow → artifact</strong>.</p>
  </section>

  <section class="progress-block">
    <div class="progress-meta">
      <span>{stats.refined} refined · {stats.shipped} shipped · {stats.total} chapters</span>
      <span>v{handbookVersion}</span>
    </div>
    <div
      class="progress-bar"
      role="progressbar"
      aria-valuenow={stats.progress}
      aria-valuemin="0"
      aria-valuemax="100"
      aria-label="Chapters refined or battle-tested"
    >
      <span style={`width: ${stats.progress}%`}></span>
    </div>
    <p class="progress-hint">
      Maturity tracks depth — refined chapters include scenarios and falsifiers.
    </p>
  </section>

  {featured.length > 0 && (
    <section class="featured-chapters">
      <h2 class="section-title">Depth pass chapters</h2>
      <p class="section-intro">Start here for the fullest essays — composite scenarios and falsifiers included.</p>
      <ul class="featured-list">
        {featured.map((chapter) => (
          <li>
            <a class="featured-card" href={chapter.href}>
              <span class={`status status-maturity status-maturity-${chapter.maturity}`}>
                {chapter.maturity}
              </span>
              <span class="featured-card-title">{chapter.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <p class="catalog-cta">
    <a href="/catalog">Full catalog →</a>
    <span class="catalog-cta-meta">{stats.total} chapters across Foundations, Discover, Shape, Own, Ship, Grow</span>
  </p>

  <p class="home-credit">
    Inspired by <a href="https://www.makingsoftware.com/">Making Software</a>
    and <a href="https://aiengineeringfromscratch.com/">AI Engineering from Scratch</a> —
    in the voice of <a href="https://angelguirao.com/wiki">footnotes</a>.
  </p>
</BaseLayout>
