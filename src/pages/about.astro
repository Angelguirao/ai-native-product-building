---
import BaseLayout from "../layouts/BaseLayout.astro";
import { handbookVersion } from "../data/catalog";
---

<BaseLayout title="About" description="Colophon and how to use this handbook." current="about">
  <p class="hero-eyebrow">Colophon</p>
  <h1 class="hero-title">About</h1>

  <div class="prose">
    <p>
      <strong>AI-Native Product Building</strong> is a living handbook by
      <a href="https://angelguirao.com/">Angel Guirao</a> — product-minded engineer, venture builder, backend at scale.
      It sits beside <a href="https://angelguirao.com/">mesh</a>, <a href="https://angelguirao.com/wiki">footnotes</a>,
      and <a href="https://holzen.app">Holzen</a> in the personal stack.
    </p>

    <h2>Source</h2>
    <p>
      Chapters live as MDX in GitHub. Drafts start in <strong>brain</strong> (private folio); shipped chapters promote here.
      Individual principles may spin out to footnotes when sharp enough to stand alone.
    </p>

    <h2>Versioning</h2>
    <p>
      Current handbook version: <strong>v{handbookVersion}</strong>. This is not a finished book — it is software-shaped writing.
      Ship a chapter, gather signal, revise.
    </p>

    <h2>License</h2>
    <p>MIT. Fork, cite, teach — keep the decision frameworks, replace the tooling.</p>

    <h2>Clone</h2>
    <pre><code>git clone https://github.com/Angelguirao/ai-native-product-building.git</code></pre>
  </div>
</BaseLayout>
