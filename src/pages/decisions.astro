---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildDecisionIndex, groupDecisionsByPhase } from "../lib/decisions";

const decisions = await buildDecisionIndex();
const phases = groupDecisionsByPhase(decisions);
---

<BaseLayout
  title="Decisions"
  description="Quick-reference decision registry — every chapter decision in one place."
  wide={true}
  current="decisions"
>
  <p class="hero-eyebrow">DEC registry · handbook reference</p>
  <h1 class="hero-title hero-title--compact">Decisions</h1>
  <p class="hero-lede">
    Timeless rules from the handbook — read here for the constitution, open chapters for workflow and artifacts.
  </p>

  <nav class="decisions-jump" aria-label="Jump to phase">
    {phases.map((group) => (
      <a href={`#phase-${group.phase}`}>{group.phaseTitle}</a>
    ))}
  </nav>

  {phases.map((group) => (
    <section class="decisions-phase" id={`phase-${group.phase}`}>
      <h2 class="decisions-phase-title">
        {group.phase} · {group.phaseTitle}
      </h2>
      <div class="decisions-index">
        {group.decisions.map((d) => (
          <article class="decision-card" id={d.figureId ?? d.chapterId}>
            <header class="decision-card-head">
              <div>
                {d.figureId && <p class="figure-id">{d.figureId}</p>}
                <h3>
                  <a href={`/chapters/${d.chapterId}`}>{d.chapterTitle}</a>
                </h3>
              </div>
            </header>
            {d.figureCaption && (
              <p class="decision-card-caption">{d.figureCaption}</p>
            )}
            <div class="decision-card-body">
              {d.body.split("\n\n").map((para) => (
                <p>{para}</p>
              ))}
            </div>
          </article>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
