---
import BaseLayout from "../layouts/BaseLayout.astro";
import { buildDecisionIndex } from "../lib/decisions";

const decisions = await buildDecisionIndex();
---

<BaseLayout
  title="Decisions"
  description="Quick-reference decision registry — every chapter decision in one place."
  wide={true}
  current="decisions"
>
  <p class="hero-eyebrow">DEC registry · handbook reference</p>
  <h1 class="hero-title" style="font-size: clamp(1.75rem, 4vw, 2.25rem)">Decisions</h1>
  <p class="hero-lede">
    Timeless rules from the handbook — read here for the constitution, open chapters for workflow and artifacts.
  </p>

  <section class="decisions-index">
    {decisions.map((d) => (
      <article class="decision-card" id={d.figureId ?? d.chapterId}>
        <header class="decision-card-head">
          <div>
            {d.figureId && <p class="figure-id">{d.figureId}</p>}
            <h2>
              <a href={`/chapters/${d.chapterId}`}>{d.chapterTitle}</a>
            </h2>
            <p class="decision-card-meta">
              {d.phase} · {d.phaseTitle}
            </p>
          </div>
        </header>
        {d.figureCaption && (
          <p class="decision-card-caption">{d.figureCaption}</p>
        )}
        <div class="decision-card-body">
          {d.body.split("\n\n").map((para) => (
            <p>{para}</p>
          ))}
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
