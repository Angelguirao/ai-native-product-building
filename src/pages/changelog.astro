---
import BaseLayout from "../layouts/BaseLayout.astro";
import { handbookVersion } from "../data/catalog";

const changelog = [
  {
    version: "1.4.1",
    date: "2026-07-14",
    items: [
      "Lenny corpus resource — discovery and product engineering OS chapters",
      "Query template templates/lenny-corpus-query.md for cited PM second opinions",
    ],
  },
  {
    version: "1.4.0",
    date: "2026-07-14",
    items: [
      "New chapter Product engineering OS — loops, skills, tools, MCPs, agents; personal vs organizational compound",
      "Fixed phase listings — Foundations and Ship on homepage and about",
      "Resources: AI PM OS, Remy, harness engineering, Business Engineer Agent OS, Builder-PM Manifesto",
      "Product engineer trail and glossary updated",
    ],
  },
  {
    version: "1.3.1",
    date: "2026-07-12",
    items: [
      "Pagefind search in header — ⌘K / Ctrl+K",
      "Glossary chapter cross-links and per-chapter term lists",
    ],
  },
  {
    version: "1.3.0",
    date: "2026-07-12",
    items: [
      "UX pass — slimmer header, homepage entry cards, featured refined chapters",
      "Chapter breadcrumbs, on-this-page TOC, styled tables, related section",
      "Decisions grouped by phase with jump nav",
    ],
  },
  {
    version: "1.2.4",
    date: "2026-07-12",
    items: [
      "Chapters 11 and 17 reference new footnotes spin-outs in principle and further reading",
    ],
  },
  {
    version: "1.2.3",
    date: "2026-07-12",
    items: [
      "Footnotes spin-outs: AI-native not bolted on (ch. 11), Organization as intelligence (ch. 17)",
      "Synthesis from Thinking.inc build guide and Block org-design essay",
    ],
  },
  {
    version: "1.2.2",
    date: "2026-07-12",
    items: [
      "Footnotes spin-outs: Builders over handoffs (ch. 01), Deliberate generalism (ch. 02)",
      "Synthesis from Builder Manifesto and generalists reading list",
    ],
  },
  {
    version: "1.2.1",
    date: "2026-07-12",
    items: [
      "Resources page at /resources — all sources mapped to chapters",
      "Six new sources from brain captures (Thinking.inc guide, Builder Manifesto, generalists list, Thinking Machines, Block, It's Time to Build)",
      "Expanded chapter mappings for existing resources",
      "Rewritten About page",
    ],
  },
  {
    version: "1.2.0",
    date: "2026-07-12",
    items: [
      "Maturity labels (shipped / refined) and honest homepage progress",
      "Decision registry at /decisions",
      "Reading trails by role at /trails",
      "Chapter prev/next navigation",
      "Public-only resource blocks — pattern cards, no private repo paths",
      "Refined chapters: validation, leave the prototype, agentic development",
    ],
  },
  {
    version: "1.1.0",
    date: "2026-07-09",
    items: [
      "Resource loop — chapter resources, footnotes spin-outs, case study scaffolding",
      "All 18 chapters shipped (v1 essays)",
    ],
  },
  {
    version: "1.0.0",
    date: "2026-07-08",
    items: ["Initial handbook catalog and chapter scaffold"],
  },
];
---

<BaseLayout title="Changelog" description="Handbook version history." footerCurrent="changelog">
  <p class="hero-eyebrow">v{handbookVersion}</p>
  <h1 class="hero-title" style="font-size: clamp(1.75rem, 4vw, 2.25rem)">Changelog</h1>
  <p class="hero-lede">Versioned in public like software — structure and content bumps tracked here.</p>

  <div class="changelog">
    {changelog.map((entry) => (
      <section class="changelog-entry">
        <h2>
          v{entry.version}
          <span class="changelog-date">{entry.date}</span>
        </h2>
        <ul>
          {entry.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
