---
import BaseLayout from "../layouts/BaseLayout.astro";
import { glossaryTerms } from "../data/glossary";
import { getOrderedChapters } from "../lib/catalog";

const chapters = await getOrderedChapters();
const titles = new Map(chapters.map((c) => [c.slug, c.title]));

const byLetter = new Map<string, typeof glossaryTerms>();
for (const term of glossaryTerms) {
  const letter = term.term[0]!.toUpperCase();
  if (!byLetter.has(letter)) byLetter.set(letter, []);
  byLetter.get(letter)!.push(term);
}
const letters = [...byLetter.keys()].sort();
---

<BaseLayout title="Glossary" description="Terms used across the handbook." footerCurrent="glossary">
  <p class="hero-eyebrow">Reference · {glossaryTerms.length} terms</p>
  <h1 class="hero-title">Glossary</h1>
  <p class="hero-lede">
    Shared vocabulary across chapters — each term links to where it is defined in depth.
  </p>

  <nav class="glossary-jump" aria-label="Jump to letter">
    {letters.map((letter) => (
      <a href={`#letter-${letter}`}>{letter}</a>
    ))}
  </nav>

  {letters.map((letter) => (
    <section class="glossary-section">
      <h2 class="glossary-letter" id={`letter-${letter}`}>{letter}</h2>
      <dl class="glossary-list">
        {byLetter.get(letter)!.map((item) => (
          <>
            <dt id={item.id}>{item.term}</dt>
            <dd>
              <p>{item.def}</p>
              <p class="glossary-chapters">
                <span class="glossary-chapters-label">Chapters:</span>
                {item.chapters.map((chapterId, index) => (
                  <>
                    {index > 0 && ", "}
                    <a href={`/chapters/${chapterId}`}>
                      {titles.get(chapterId) ?? chapterId}
                    </a>
                  </>
                ))}
              </p>
            </dd>
          </>
        ))}
      </dl>
    </section>
  ))}
</BaseLayout>
