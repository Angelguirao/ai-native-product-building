---
import { getCollection, render } from "astro:content";
import ChapterLayout from "../../layouts/ChapterLayout.astro";
import ChapterResources from "../../components/ChapterResources.astro";
import { getChapterNav } from "../../lib/catalog";

export async function getStaticPaths() {
  const chapters = await getCollection("chapters");
  return chapters.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const nav = await getChapterNav(entry.id);
---

<ChapterLayout
  title={entry.data.title}
  description={entry.data.description}
  phase={entry.data.phase}
  phaseTitle={entry.data.phaseTitle}
  status={entry.data.status}
  maturity={entry.data.maturity}
  nav={nav}
>
  <Content />
  <ChapterResources chapterId={entry.id} />
</ChapterLayout>
