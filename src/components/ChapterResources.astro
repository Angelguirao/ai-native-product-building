---
import {
  getChapterCaseStudies,
  getChapterResources,
  getChapterSpinOut,
} from "../data/resources";

type Props = {
  chapterId: string;
};

const { chapterId } = Astro.props;
const resources = getChapterResources(chapterId);
const spinOut = getChapterSpinOut(chapterId);
const cases = getChapterCaseStudies(chapterId);

const hasContent = resources.length > 0 || spinOut || cases.length > 0;
---

{hasContent && (
  <section class="chapter-resources">
    {spinOut && (
      <div class="resource-block">
        <h2>Footnotes spin-out</h2>
        <p class="resource-intro">
          Sharp principle distilled for the wiki — improves as folio synthesis grows.
        </p>
        <ul class="resource-list">
          <li>
            <a href={spinOut.url}>{spinOut.title}</a>
            <span class="resource-meta"> · footnotes</span>
          </li>
        </ul>
      </div>
    )}

    {resources.length > 0 && (
      <div class="resource-block">
        <h2>Recommended resources</h2>
        <p class="resource-intro">
          Captured raw in <code>brain/raw/</code> — run compile, synthesize, then revise this chapter.
        </p>
        <ul class="resource-list">
          {resources.map((r) => (
            <li>
              <a href={r.url} rel="noopener noreferrer">{r.title}</a>
              <span class="resource-meta"> · {r.kind}</span>
              {r.note && <p class="resource-note">{r.note}</p>}
              {r.brainRaw && (
                <p class="resource-brain">
                  <span>brain:</span> <code>raw/{r.brainRaw}.md</code>
                </p>
              )}
            </li>
          ))}
        </ul>
      </div>
    )}

    {cases.length > 0 && (
      <div class="resource-block">
        <h2>Case studies</h2>
        <ul class="resource-list">
          {cases.map((c) => (
            <li>
              {c.url ? (
                <a href={c.url} rel="noopener noreferrer">{c.title}</a>
              ) : (
                <strong>{c.title}</strong>
              )}
              <p class="resource-note">{c.summary}</p>
              <p class="resource-brain">
                <span>brain:</span> <code>raw/{c.brainRaw}.md</code>
              </p>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}
