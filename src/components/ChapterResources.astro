---
import {
  getChapterCaseStudies,
  getChapterResources,
  getChapterSpinOut,
} from "../data/resources";

type Props = {
  chapterId: string;
};

const { chapterId } = Astro.props;
const resources = getChapterResources(chapterId);
const spinOut = getChapterSpinOut(chapterId);
const cases = getChapterCaseStudies(chapterId);

const hasContent = resources.length > 0 || spinOut || cases.length > 0;
---

{hasContent && (
  <section class="chapter-resources">
    {spinOut && (
      <div class="resource-block">
        <h2>Related principle</h2>
        <p class="resource-intro">
          Distilled essay on the public wiki — same idea in tighter form.
        </p>
        <ul class="resource-list">
          <li>
            <a href={spinOut.url} rel="noopener noreferrer">{spinOut.title}</a>
            <span class="resource-meta"> · footnotes</span>
          </li>
        </ul>
      </div>
    )}

    {resources.length > 0 && (
      <div class="resource-block">
        <h2>Recommended resources</h2>
        <p class="resource-intro">
          External books, courses, and essays that informed this chapter.
        </p>
        <ul class="resource-list">
          {resources.map((r) => (
            <li>
              <a href={r.url} rel="noopener noreferrer">{r.title}</a>
              <span class="resource-meta"> · {r.kind}</span>
              {r.note && <p class="resource-note">{r.note}</p>}
            </li>
          ))}
        </ul>
      </div>
    )}

    {cases.length > 0 && (
      <div class="resource-block">
        <h2>Pattern cards</h2>
        <p class="resource-intro">
          Anonymous composite scenarios — useful shapes, not specific companies.
        </p>
        <ul class="resource-list">
          {cases.map((c) => (
            <li>
              <strong>{c.title}</strong>
              <p class="resource-note">{c.summary}</p>
            </li>
          ))}
        </ul>
      </div>
    )}
  </section>
)}
