---
type Props = {
  current?: "home" | "catalog" | "about" | "glossary" | "decisions" | "trails" | "changelog";
};

const { current } = Astro.props;
---

<header class="site-header">
  <a class="site-brand" href="/">AI-Native Product Building</a>
  <nav class="site-nav" aria-label="Handbook">
    <a href="/catalog" aria-current={current === "catalog" ? "page" : undefined}>Catalog</a>
    <a href="/trails" aria-current={current === "trails" ? "page" : undefined}>Trails</a>
    <a href="/decisions" aria-current={current === "decisions" ? "page" : undefined}>Decisions</a>
    <a href="/glossary" aria-current={current === "glossary" ? "page" : undefined}>Glossary</a>
    <a href="/changelog" aria-current={current === "changelog" ? "page" : undefined}>Changelog</a>
    <a href="/about" aria-current={current === "about" ? "page" : undefined}>About</a>
    <a href="https://angelguirao.com/wiki" rel="noopener">footnotes</a>
  </nav>
</header>
